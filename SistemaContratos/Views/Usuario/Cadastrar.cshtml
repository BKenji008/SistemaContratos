@model SistemaContratos.Models.Usuario

@{
    ViewData["Title"] = "Cadastro de Usuário";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="text-center mb-4">
            <h2 class="text-dark fw-bold">Criar Conta</h2>
            <p class="text-muted">Preencha os dados para criar sua conta</p>
        </div>

        <div class="card shadow bg-white border" style="border-radius: 10px;">
            <div class="card-body p-4">
                @if (TempData["Erro"] != null)
                {
                    <div class="alert alert-danger text-center shadow-sm">@TempData["Erro"]</div>
                }
                <form asp-controller="Usuario" asp-action="Cadastrar" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome</label>
                        <input type="text" asp-for="Nome" class="form-control" placeholder="Ex: João da Silva" required autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome de Usuário</label>
                        <input type="text" asp-for="Login" class="form-control" placeholder="joao.silva" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Senha</label>
                        <input type="password" asp-for="Senha" class="form-control" placeholder="Crie uma senha" required />
                    </div>
                    
                    <button type="submit" class="btn btn-success w-100 mb-3 shadow-sm">Finalizar Cadastro</button>
                    
                    <div class="text-center mt-3">
                        <a asp-action="Login" class="text-decoration-none">Retonar ao login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>