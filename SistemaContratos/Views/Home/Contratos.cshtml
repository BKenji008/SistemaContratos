@model IEnumerable<SistemaContratos.Models.Contrato>

@{
    ViewData["Title"] = "Consulta de Contratos";
}

<div class="mt-4">
    <h2 class="mb-4">Todos os Contratos</h2>
    
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover shadow-sm border">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>Contrato</th>
                        <th>Produto</th>
                        <th>Vencimento</th>
                        <th>Valor</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contrato in Model)
                    {
                        <tr>
                            <td>@contrato.NomeCliente</td>
                            <td>@contrato.CPF</td>
                            <td>@contrato.NumContrato</td>
                            <td>@contrato.Produto</td>
                            <td>@contrato.DataVencimento.ToShortDateString()</td>
                            <td>@contrato.Valor.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Nenhum contrato encontrado. Faça a importação primeiro.</div>
    }
</div>